# Copy to .env (gitignored) and fill in. FVT_CODE is a credential.

# The public API the runner drives. The gateway and platform-auth sit behind this one host — nginx
# routes /mcp and /health to vmcp and /auth to platform-auth — so both URLs are the same. Driving the
# PUBLIC endpoint (not an in-cluster address) is the whole point: it exercises the same path a real
# MCP client takes, through Cloudflare and nginx.
VMCP_URL=https://api-andres.project-platform.me
AUTH_URL=https://api-andres.project-platform.me

# The runner's identity in platform-auth. It self-provisions this account on first run (POST
# /auth/identities) and signs in for a fresh token every run thereafter. The username is PUBLIC — it
# shows in the dashboard's User column — so keep it recognisable, not secret.
FVT_USER=fvt-runner

# The runner's password/pin — at least 4 characters. This is the only secret here: anyone holding it
# can post traffic as fvt-runner. Don't reuse a password you use anywhere else. The .env copy of this
# file is gitignored; keep it that way.
FVT_CODE=

# Seconds between runs. 14400 = every 4 hours, the cadence the in-cluster Deployment used.
FVT_INTERVAL_SECONDS=14400
