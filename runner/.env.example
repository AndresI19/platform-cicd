# Copy to .env (gitignored) and fill in. Both of these are credentials.

# Which repo the runner registers to. It is scoped to exactly one, by GitHub's design.
GH_REPO=AndresI19/platform-cicd

# A FINE-GRAINED token, scoped to platform-cicd ONLY, with:
#     Repository permissions → Administration: Read and write
#
# Only used to mint a registration token. An ephemeral runner de-registers after every job, so a fresh
# registration token is needed on every start, and a token handed in at setup would go stale within the
# hour — which is why this is a PAT, not a one-off token.
#   github.com → Settings → Developer settings → Personal access tokens → Fine-grained tokens
GH_PAT=

# The `deployer` ServiceAccount's kubeconfig, base64'd. Passed in the ENVIRONMENT, not mounted: the VM
# sees exactly one host directory, so an env var needs no window into the host.
#
#   kubectl -n platform get secret deployer-token -o jsonpath='{.data.token}' | base64 -d
#   (see the README — or just re-run scripts/kubeconfig.sh)
KUBECONFIG_B64=
